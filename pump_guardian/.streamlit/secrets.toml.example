# Copy this file to `secrets.toml` in the same folder (`.streamlit/secrets.toml`).
# Streamlit automatically loads it; values are merged into the app (see core/config.py).
# Do NOT commit secrets.toml.

# --- Flat keys (same names as environment variables) ---
MINIMAX_API_KEY = "paste-your-key-here"
MINIMAX_API_BASE = "https://api.minimax.io"
MINIMAX_MODEL = "MiniMax-M2.5"

# --- Optional nested form (alternative to flat keys above) ---
# [minimax]
# api_key = "paste-your-key-here"
# api_base = "https://api.minimax.io"
# model = "MiniMax-M2.5"
